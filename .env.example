# --- Database (Postgres / Supabase) ---
# Use the pooled connection string for runtime (Transaction mode pooler).
# On Supabase this is shown as "Connection pooling -> Transaction" or the POSTGRES_URL
# variable from the Vercel <> Supabase integration.
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Used by `npm run db:seed` and `drizzle-kit push` for DDL / migrations
# (direct, non-pooled 5432 connection).
POSTGRES_URL_NON_POOLING=postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Random string, 32+ chars. Used to sign session cookies.
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars

# First admin user, created by `npm run db:seed` if the users table is empty.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-run

# --- Optional: parent message translations ---
DEEPL_API_KEY=
DEEPL_API_HOST=https://api-free.deepl.com
